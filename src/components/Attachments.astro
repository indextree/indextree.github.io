---
/**
 * Attachments component
 * Renders a list of downloadable file attachments for blog posts.
 */

interface Attachment {
    name: string;
    file: string;
    size?: string;
}

interface Props {
    attachments?: Attachment[];
    title?: string;
}

const { attachments, title = "Attachments" } = Astro.props;

// Map file extension to a human-readable type label
function getFileType(filename: string): string {
    const ext = filename.split(".").pop()?.toLowerCase() ?? "";
    const typeMap: Record<string, string> = {
        pdf: "PDF",
        doc: "DOC",
        docx: "DOCX",
        xls: "XLS",
        xlsx: "XLSX",
        ppt: "PPT",
        pptx: "PPTX",
        csv: "CSV",
        txt: "TXT",
        zip: "ZIP",
        rar: "RAR",
    };
    return typeMap[ext] ?? ext.toUpperCase();
}

// Pick a color class based on extension
function getBadgeColor(filename: string): string {
    const ext = filename.split(".").pop()?.toLowerCase() ?? "";
    const colorMap: Record<string, string> = {
        pdf: "bg-red-100 text-red-700",
        doc: "bg-blue-100 text-blue-700",
        docx: "bg-blue-100 text-blue-700",
        xls: "bg-green-100 text-green-700",
        xlsx: "bg-green-100 text-green-700",
        ppt: "bg-orange-100 text-orange-700",
        pptx: "bg-orange-100 text-orange-700",
        csv: "bg-green-100 text-green-700",
        txt: "bg-gray-100 text-gray-700",
        zip: "bg-yellow-100 text-yellow-700",
        rar: "bg-yellow-100 text-yellow-700",
    };
    return colorMap[ext] ?? "bg-gray-100 text-gray-700";
}
---

{
    attachments && attachments.length > 0 && (
        <aside class="mt-10 mb-6 border border-black/10 rounded-xl p-5" aria-label={title}>
            <h3 class="flex items-center gap-2 text-lg font-bold mb-4 text-black/80">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48" />
                </svg>
                {title}
            </h3>
            <ul class="space-y-2 list-none p-0 m-0">
                {attachments.map((att) => (
                    <li>
                        <a
                            href={att.file}
                            download
                            class="group flex items-center gap-3 p-3 rounded-lg bg-black/[0.03] hover:bg-purple-100 transition-colors no-underline text-black/80 hover:text-purple-700"
                            aria-label={`Download ${att.name}`}
                        >
                            <span
                                class={`text-xs font-bold px-2 py-1 rounded-md shrink-0 uppercase ${getBadgeColor(att.file)}`}
                            >
                                {getFileType(att.file)}
                            </span>
                            <span class="flex flex-col flex-1 min-w-0">
                                <span class="text-sm font-medium truncate">{att.name}</span>
                                {att.size && (
                                    <span class="text-xs text-black/50">
                                        {att.size}
                                    </span>
                                )}
                            </span>
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="shrink-0 opacity-50 group-hover:opacity-100"
                                aria-hidden="true"
                            >
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                                <polyline points="7 10 12 15 17 10" />
                                <line x1="12" y1="15" x2="12" y2="3" />
                            </svg>
                        </a>
                    </li>
                ))}
            </ul>
        </aside>
    )
}


